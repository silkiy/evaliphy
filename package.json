{
  "name": "evaliphy",
  "version": "1.0.1-beta.1",
  "type": "module",
  "description": "The first QA-centric SDK for testing Retrieval-Augmented Generation (RAG).",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "keywords": [
    "evaliphy",
    "evaluate",
    "rag",
    "llm",
    "qa",
    "testing",
    "ai",
    "evaluation"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "homepage": "https://evaliphy.com",
  "bugs": {
    "url": "https://github.com/priyanshus/evaliphy/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/priyanshus/evaliphy.git"
  },
  "license": "MIT",
  "author": "Evaliphy",
  "engines": {
    "node": ">=18.0.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.mts"
    }
  },
  "bin": {
    "evaliphy": "./dist/bin.mjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "commander": "catalog:",
    "fast-glob": "^3.3.3",
    "tsx": "catalog:",
    "zod": "catalog:",
    "picocolors": "^1.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "@types/node": "catalog:"
  }
}
