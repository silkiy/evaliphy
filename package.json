{
  "name": "evaliphy",
  "version": "1.0.1-beta.9",
  "type": "module",
  "description": "The first QA-centric SDK for testing Retrieval-Augmented Generation (RAG).",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "keywords": [
    "evaliphy",
    "evaluate",
    "rag",
    "llm",
    "qa",
    "testing",
    "ai",
    "rag-evaluation",
    "evaluation"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "homepage": "https://evaliphy.com",
  "bugs": {
    "url": "https://github.com/Evaliphy/evaliphy/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Evaliphy/evaliphy.git"
  },
  "license": "MIT",
  "author": "Evaliphy",
  "engines": {
    "node": ">=24.0.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.mts"
    }
  },
  "bin": {
    "evaliphy": "dist/bin.mjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "fast-glob": "^3.3.3",
    "tsx": "^4.21.0",
    "zod": "^3.0.7",
    "picocolors": "^1.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "tsdown": "^0.21.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@types/node": "^20.0.0"
  }
}
